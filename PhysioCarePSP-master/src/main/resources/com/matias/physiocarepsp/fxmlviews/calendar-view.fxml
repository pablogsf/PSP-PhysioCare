<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.calendarfx.view.CalendarView?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.matias.physiocarepsp.viewscontroller.CalendarController"
      spacing="10"
      alignment="CENTER"
      prefWidth="900" prefHeight="700">

    <!-- Título -->
    <Label text="Calendario de Citas"
           style="-fx-font-size: 24px; -fx-font-weight: bold;" />

    <!-- FORMULARIO CREAR CITA -->
    <HBox spacing="10" alignment="CENTER">
        <ComboBox fx:id="patientComboBox" promptText="Selecciona paciente" prefWidth="180"/>
        <ComboBox fx:id="physioComboBox"  promptText="Selecciona fisio"   prefWidth="180"/>
        <DatePicker fx:id="datePicker"       promptText="Fecha"             prefWidth="140"/>
        <Spinner fx:id="hourSpinner"         prefWidth="80"/>
        <Button fx:id="createAppointmentButton"
                text="Crear cita" />
    </HBox>

    <!-- FORMULARIO EDITAR CITA SELECCIONADA -->
    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="diagnosisField"    promptText="Diagnóstico"    prefWidth="200"/>
        <TextField fx:id="treatmentField"    promptText="Tratamiento"    prefWidth="200"/>
        <TextField fx:id="observationsField" promptText="Observaciones"  prefWidth="200"/>
        <Button fx:id="updateAppointmentButton"
                text="Actualizar cita" />
    </HBox>

    <!-- VISTA DEL CALENDARIO -->
    <CalendarView fx:id="calendarView"
                  VBox.vgrow="ALWAYS"
                  prefWidth="900"
                  prefHeight="500" />

    <!-- Botón de volver atrás -->
    <Button text="Volver al Menú"
            onAction="#onBackButtonClick" />

</VBox>
